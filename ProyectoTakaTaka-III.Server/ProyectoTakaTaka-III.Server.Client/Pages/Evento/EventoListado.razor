@page "/eventos"
@rendermode InteractiveAuto
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ProyectoTakaTaka_III.Servicio.ServicioHttp
@using ProyectoTakaTaka_III.Shared.DTO
@inject IHttpServicio http
@inject NavigationManager navHttp
@inject AuthenticationStateProvider AuthenticationStateProvider


<h3>Listado de Eventos</h3>
<br />
<a class="btn btn-primary" href="/eventos/crear">Nuevo evento</a>
<br />
<br />

@if (eventos == null)
{
    <p>Cargando eventos...</p>
}
else if (eventos.Count == 0)
{
    <p>No hay eventos registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Evento</th>
                <th>Pagos</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var ev in eventos)
            {
                <tr>
                    <td>
                        <strong>@ev.Evento</strong>
                        <br />
                        <small class="text-muted">
                            @ev.Fecha.ToString("dd/MM/yyyy")
                        </small>
                    </td>

                    <td>
                        @(ev.Pagos?.Count ?? 0)
                    </td>

                    <td>
                        <div class="action-buttons">

                            <!-- BOTÓN VER -->
                            <button type="button"
                                    class="btn-icono btn-ver"
                                    title="Ver detalle"
                                    @onclick="() => ToggleDetalle(ev.Id)">

                                👁️
                            </button>

                            <!-- BOTÓN ELIMINAR -->
                            @if (esAdmin)
                            {
                                <button type="button"
                                        class="btn-icono btn-eliminar"
                                        title="Eliminar"
                                        @onclick="() => Borrar(ev)">
                                    🗑️
                                </button>
                            }

                        </div>
                    </td>
                </tr>

                @if (eventoExpandido == ev.Id)
                {
                    <tr class="detalle-row">
                        <td colspan="3">

                            <div class="evento-detalle">

                                <p><b>Cliente:</b> @ev.Cliente</p>
                                <p><b>Cumpleañero:</b> @ev.Cumpleanero</p>
                                <p><b>Edad:</b> @ev.Edad</p>
                                <p><b>Combo:</b> @ev.Combo</p>
                                <p><b>Horario:</b> @($"{ev.HInicio} - {ev.HFin}")</p>
                                <p><b>Temática:</b> @ev.Tematica</p>
                                <p><b>Opcionales:</b> @string.Join(", ", ev.Opcionales)</p>

                            </div>

                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

<br />
<p class="text-danger">@Mensaje</p>

@code {
    List<ListadoEventoDTO>? eventos;
    string Mensaje = "";
    int? eventoExpandido = null; 
    bool esAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var usuario = authState.User;

        esAdmin = usuario.IsInRole("Admin");

        await LeerEventos();
    }

    private async Task LeerEventos()
    {
        var resp = await http.Get<List<ListadoEventoDTO>>("api/Evento/ListadoEvento");
        if (!resp.Error)
        {
            eventos = resp.Respuesta;
        }
        else
        {
            Mensaje = resp.ObtenerError();
        }
    }

    private void ToggleDetalle(int id)
    {
        if (eventoExpandido == id)
            eventoExpandido = null;
        else
            eventoExpandido = id;
    }

    private async Task Borrar(ListadoEventoDTO ev)
    {
        var resp = await http.Delete($"api/Evento/{ev.Id}");
        if (resp.Error)
        {
            Mensaje = resp.ObtenerError();
        }
        else
        {
            Mensaje = "Evento eliminado correctamente.";
        }

        await LeerEventos();
    }
}
